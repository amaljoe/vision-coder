\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}The Generation-Length Lifecycle}{10}{subsection.5.1}\protected@file@percent }
\newlabel{sec:length}{{5.1}{10}{The Generation-Length Lifecycle}{subsection.5.1}{}}
\@writefile{toc}{\contentsline {paragraph}{Phase 1 — Verbose Exploration (steps 1--10).}{10}{section*.23}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Phase 2 — Brevity Collapse (steps 10--100).}{10}{section*.24}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Qualitative comparison on three Design2Code examples (testset indices 158, 5, 428). Numbers in parentheses are the Design2Code Overall scores. Rows 1--2 illustrate the policy collapse of VisionCoder-RL (white-page degenerate output), in stark contrast to VisionCoder-SFT+RL's faithful reproductions. Row 3 shows a case where VisionCoder-RL succeeds (0.896), demonstrating the inconsistency of RL-only training without a SFT warm-start.\relax }}{11}{figure.caption.21}\protected@file@percent }
\newlabel{fig:qualitative}{{2}{11}{Qualitative comparison on three Design2Code examples (testset indices 158, 5, 428). Numbers in parentheses are the Design2Code Overall scores. Rows 1--2 illustrate the policy collapse of VisionCoder-RL (white-page degenerate output), in stark contrast to VisionCoder-SFT+RL's faithful reproductions. Row 3 shows a case where VisionCoder-RL succeeds (0.896), demonstrating the inconsistency of RL-only training without a SFT warm-start.\relax }{figure.caption.21}{}}
\@writefile{toc}{\contentsline {paragraph}{Phase 3 — Visual Awakening ($\approx $step 100).}{11}{section*.25}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Generation length statistics (mean, min, max) over GRPO training steps. The four phases of the generation-length lifecycle are visible: (1) verbose exploration with frequent truncation, (2) brevity collapse as the model avoids truncation penalties, (3) visual awakening as CLIP reward incentivises richer HTML, and (4) stable expressive equilibrium. The CLIP-enabled run maintains longer completions ($\approx $456 tokens) than the no-CLIP run ($\approx $339 tokens), because richer HTML earns higher visual reward.\relax }}{12}{figure.caption.22}\protected@file@percent }
\newlabel{fig:completions}{{3}{12}{Generation length statistics (mean, min, max) over GRPO training steps. The four phases of the generation-length lifecycle are visible: (1) verbose exploration with frequent truncation, (2) brevity collapse as the model avoids truncation penalties, (3) visual awakening as CLIP reward incentivises richer HTML, and (4) stable expressive equilibrium. The CLIP-enabled run maintains longer completions ($\approx $456 tokens) than the no-CLIP run ($\approx $339 tokens), because richer HTML earns higher visual reward.\relax }{figure.caption.22}{}}
\@writefile{toc}{\contentsline {paragraph}{Phase 4 — Expressive Equilibrium (steps 200+).}{12}{section*.26}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Reward Phase Transitions}{12}{subsection.5.2}\protected@file@percent }
\newlabel{sec:reward_curves}{{5.2}{12}{Reward Phase Transitions}{subsection.5.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Per-component reward curves during GRPO training. Format and validity rewards (dashed) converge to near-perfect within 50 steps. The CLIP visual reward (orange) only activates in runs where it is included as a training signal; without CLIP, the total reward plateaus at $\approx $2.5. The phase transition at step $\approx $100 corresponds to the visual awakening described in Section\nobreakspace  {}\ref  {sec:length}.\relax }}{13}{figure.caption.27}\protected@file@percent }
\newlabel{fig:rewards}{{4}{13}{Per-component reward curves during GRPO training. Format and validity rewards (dashed) converge to near-perfect within 50 steps. The CLIP visual reward (orange) only activates in runs where it is included as a training signal; without CLIP, the total reward plateaus at $\approx $2.5. The phase transition at step $\approx $100 corresponds to the visual awakening described in Section~\ref {sec:length}.\relax }{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}The Necessity of SFT Warm-Starting}{13}{subsection.5.3}\protected@file@percent }
\newlabel{sec:coldstart}{{5.3}{13}{The Necessity of SFT Warm-Starting}{subsection.5.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Training dynamics: policy entropy and loss over GRPO training steps. Entropy decreases monotonically in both runs, indicating convergence to a confident policy. The CLIP-enabled run maintains higher entropy ($\approx $0.16 at step 500) than the no-CLIP run ($\approx $0.07), reflecting the visual reward's incentive for exploring diverse HTML approaches across different reference screenshots.\relax }}{14}{figure.caption.28}\protected@file@percent }
\newlabel{fig:dynamics}{{5}{14}{Training dynamics: policy entropy and loss over GRPO training steps. Entropy decreases monotonically in both runs, indicating convergence to a confident policy. The CLIP-enabled run maintains higher entropy ($\approx $0.16 at step 500) than the no-CLIP run ($\approx $0.07), reflecting the visual reward's incentive for exploring diverse HTML approaches across different reference screenshots.\relax }{figure.caption.28}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Entropy Dynamics and Policy Stability}{14}{subsection.5.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Distribution of CLIP reward ratios across rollouts at different training stages. At initialisation (left), CLIP rewards cluster near zero (blank-page outputs). After training (right), the distribution shifts to substantially higher values, with most rollouts earning meaningful visual reward. The long tail indicates that some reference pages remain challenging to reproduce.\relax }}{15}{figure.caption.29}\protected@file@percent }
\newlabel{fig:clipratios}{{6}{15}{Distribution of CLIP reward ratios across rollouts at different training stages. At initialisation (left), CLIP rewards cluster near zero (blank-page outputs). After training (right), the distribution shifts to substantially higher values, with most rollouts earning meaningful visual reward. The long tail indicates that some reference pages remain challenging to reproduce.\relax }{figure.caption.29}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Conclusion}{15}{section.6}\protected@file@percent }
